generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
}

enum PaymentMethod {
  cash
  card
  bank_transfer
  mobile_money
  other
}

enum ReceiptTemplate {
  minimal
  modern
  thermal
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  plan         Plan     @default(FREE)

  customers Customer[]
  products  Product[]
  receipts  Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Customer {
  id      String @id @default(cuid())
  userId  String
  name    String
  phone   String?
  email   String?
  address String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  receipts Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, name])
}

model Product {
  id     String  @id @default(cuid())
  userId String
  name   String
  sku    String?
  price  Decimal @db.Decimal(12, 2)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, name])
}

model Receipt {
  id         String          @id @default(cuid())
  userId     String
  customerId String?

  shareId String @unique @default(cuid())

  template      ReceiptTemplate @default(modern)
  currency      String
  receiptNo     String
  issueDate     DateTime
  businessName  String
  businessAddr  String?
  businessPhone String?
  customerName  String?
  customerPhone String?
  notes         String?
  paymentMethod PaymentMethod  @default(cash)
  taxRate       Decimal        @db.Decimal(6, 3)
  discount      Decimal        @db.Decimal(12, 2) @default(0)

  subtotal Decimal @db.Decimal(12, 2)
  tax      Decimal @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  logoUrl String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    ReceiptItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, issueDate])
}

model ReceiptItem {
  id        String  @id @default(cuid())
  receiptId String
  name      String
  qty       Decimal @db.Decimal(12, 3)
  price     Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
}

